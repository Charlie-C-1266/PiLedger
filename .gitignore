# ── Database ───────────────────────────────────────────────────────────────────
# Contains user credentials and financial records — never commit
*.db
*.sqlite
*.sqlite3

# ── Python runtime ─────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Test artefacts ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Claude Code ────────────────────────────────────────────────────────────────
# Everything under .claude/ is per-developer session config, not shared project
# state: settings.local.json holds permission allowlists, commands/ holds custom
# slash commands (e.g. grill-with-docs, which is also published upstream), and
# scheduled_tasks.lock is transient session scheduling state.
.claude/settings.local.json
.claude/commands/
.claude/scheduled_tasks.lock

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/*.tsbuildinfo
src/static/dist/

# ── OS / editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
